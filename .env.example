# ─── Clerk Auth ──────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → knowledgehive database → REST API
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_KEY_HERE
RESEND_FROM_EMAIL=noreply@knowledgehive.com.au

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=KnowledgeHive
VITE_APP_URL=https://knowledgehive.com.au
